{
  "name": "willtomlinson/glowmarkt-php",
  "description": "A PHP client for the Glowmarkt API",
  "type": "library",
  "license": "MIT",
  "homepage": "https://github.com/willtomlinson/glowmarkt-php",
  "require": {
    "php": "^8.4",
    "saloonphp/saloon": "^4.0",
    "saloonphp/cache-plugin": "^3.0"
  },
  "require-dev": {
    "pestphp/pest": "^4.4",
    "symfony/var-dumper": "^8.0",
    "rector/rector": "^2.4",
    "friendsofphp/php-cs-fixer": "^3.94",
    "nesbot/carbon": "^3.11"
  },
  "autoload": {
    "psr-4": {
      "GlowmarktPhp\\": "src/"
    }
  },
  "autoload-dev": {
    "classmap": [
      "tests"
    ],
    "psr-4": {
      "GlowmarktPhp\\Tests\\": "tests/"
    }
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "scripts": {
    "format": [
      "./vendor/bin/rector",
      "./vendor/bin/php-cs-fixer fix"
    ],
    "format-dryrun": [
      "./vendor/bin/rector --dry-run || true && ./vendor/bin/php-cs-fixer fix --dry-run --diff"
    ],
    "test": "./vendor/bin/pest"
  }
}
